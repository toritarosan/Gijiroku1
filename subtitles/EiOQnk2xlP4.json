    },
    {
      "start": 249.84,
      "duration": 6.799,
      "text": "調べを後ほどご覧いただきたいと思います"
    },
    {
      "start": 252.519,
      "duration": 6.84,
      "text": "。101ページをお開きください。続き"
    },
    {
      "start": 256.639,
      "duration": 7.201,
      "text": "まして再出予算でございます。"
    },
    {
      "start": 259.359,
      "duration": 10.041,
      "text": "教育費右側説明欄1学校施設整備に要する"
    },
    {
      "start": 263.84,
      "duration": 9.04,
      "text": "経費の設14第1小学校運動上整備工事"
    },
    {
      "start": 269.4,
      "duration": 7.48,
      "text": "3520万円につきましては小金第一小"
    },
    {
      "start": 272.88,
      "duration": 7.28,
      "text": "学校後舎改築等工事に伴う工程の代地と"
    },
    {
      "start": 276.88,
      "duration": 6.12,
      "text": "するため調射建設予定値の一部にゴム"
    },
    {
      "start": 280.16,
      "duration": 5.319,
      "text": "チップ舗フェンス設置等を行うもので"
    },
    {
      "start": 283.0,
