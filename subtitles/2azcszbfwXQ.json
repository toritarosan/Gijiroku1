      "text": "月以降することを求める意見書について住民主党小金を代表し反対の立場から討論をいたします。"
    },
    {
      "start": 1195.039,
      "duration": 8.441,
      "text": "先般の総務企画委員会において会派として"
    },
    {
      "start": 1199.48,
      "duration": 8.6,
      "text": "陰子制度を巡る特例措置についてはまず国"
    },
    {
      "start": 1203.48,
      "duration": 8.76,
      "text": "の議論の行方とその結果を結論を中視しの"
    },
    {
      "start": 1208.08,
      "duration": 7.0,
      "text": "声と税の公平性の双方を見極めないながら"
    },
    {
      "start": 1212.24,
      "duration": 7.76,
      "text": "慎重に判断すべきであるとの見解を述べ"
    },
    {
      "start": 1215.08,
      "duration": 8.959,
      "text": "ました。本日政府は与党税制改正対抗の"
    },
    {
      "start": 1220.0,
      "duration": 7.88,
      "text": "取りまとめを進めており、税制改正の方針"
    },
    {
      "start": 1224.039,
      "duration": 8.401,
      "text": "が決定するところですが、直近に開催され"
