    {
      "start": 1227.88,
      "duration": 8.159,
      "text": "た自民党税制調査会において消費税の"
    },
    {
      "start": 1232.44,
      "duration": 7.2,
      "text": "インボイス制度にかかる経過措置いわゆる"
    },
    {
      "start": 1236.039,
      "duration": 8.201,
      "text": "2割特例及び8割控除について内容を"
    },
    {
      "start": 1239.64,
      "duration": 8.56,
      "text": "見直した上で適用期源を延長する方向性が"
    },
    {
      "start": 1244.24,
      "duration": 7.559,
      "text": "示されました。具体的には2割特例につい"
    },
    {
      "start": 1248.2,
      "duration": 8.359,
      "text": "て事務負担への配慮がより必要とされる"
    },
    {
      "start": 1251.799,
      "duration": 8.281,
      "text": "個人事業者を対象に陰ボ制度を踏まえて、"
    },
    {
      "start": 1256.559,
      "duration": 7.961,
      "text": "え、課税転換している場合"
    },
    {
      "start": 1260.08,
      "duration": 8.36,
      "text": "納税額を、え、売上税額の3割とする経過"
    },
    {
      "start": 1264.52,
      "duration": 9.12,
      "text": "措置をさらに2年間限り公ずるとされまし"
    },
    {
      "start": 1268.44,
      "duration": 9.92,
      "text": "た。また8割については最終的な適用期限"
    },
    {
      "start": 1273.64,
      "duration": 8.36,
      "text": "を2年間延長した上で控除割合の引き下げ"
    },
    {
      "start": 1278.36,
      "duration": 8.6,
      "text": "ペースと幅を見直しし令和8年10月から"
    },
    {
