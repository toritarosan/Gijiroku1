    },
    {
      "start": 1848.799,
      "duration": 7.0,
      "text": "委員会特定事件、え、継続調査案件、え、"
    },
    {
      "start": 1853.039,
      "duration": 7.36,
      "text": "一覧表の通り、え、継続調査とすることと"
    },
    {
      "start": 1855.799,
      "duration": 7.201,
      "text": "決定しました。追加日程第4議員の派遣に"
    },
    {
      "start": 1860.399,
      "duration": 6.441,
      "text": "ついて議題とします。お諮りします。え、"
    },
    {
      "start": 1863.0,
      "duration": 7.12,
      "text": "地方自治法第100条第13項及び会議"
    },
    {
      "start": 1866.84,
      "duration": 6.76,
      "text": "規則第120条の規定に基づきお手元に"
    },
    {
      "start": 1870.12,
      "duration": 7.039,
      "text": "配布しました議員の派遣についての通り"
    },
    {
      "start": 1873.6,
      "duration": 6.72,
      "text": "閉中に議員派遣を行うこととしの事情に"
    },
    {
      "start": 1877.159,
      "duration": 5.321,
      "text": "より変更が生じた場合は議長にご一任い"
    },
    {
      "start": 1880.32,
      "duration": 4.599,
      "text": "いただくことにご異議ありませんか?え、"
    },
    {
      "start": 1882.48,
      "duration": 4.64,
      "text": "ご異議なしと認めただ今申し上げた通り"
    },
    {
      "start": 1884.919,
      "duration": 5.201,
      "text": "行うことと決定しました。"
    },
    {
      "start": 1887.12,
      "duration": 3.0,
      "text": "重ねてお諮りします。なお、閉解中に議員派遣を行う必要性が必要が生じた場合、え、その日時、場所、目的及び派遣議員等については議長に一任いただくことにご異議ありませんか?"
    },
    {
      "start": 1899.6,
      "duration": 3.559,
      "text": "あ、"
    },
    {
      "start": 1900.159,
      "duration": 3.0,
      "text": "え、ご異議なしと認め、ただいま申し上げた通り行うことと決定しました。以上で、今定例会に議された案件は全て終了しました。"
    },
    {
      "start": 1909.44,
      "duration": 5.199,
      "text": "え、これを持ちまして会議を閉じ令和"
    },
    {
      "start": 1912.12,
      "duration": 5.519,
      "text": "7年度令和7年第4"
    },
    {
      "start": 1914.639,
      "duration": 3.0,
      "text": "回、え、小金市議会定例会を閉します。"
    },
    {
      "start": 1918.679,
      "duration": 3.0,
      "text": "お疲れ様でした。"
    }
  ]
}